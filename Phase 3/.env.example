# ============================================================
# AI Research Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Required: SerpAPI Key (https://serpapi.com)
SERPAPI_API_KEY=your_serpapi_key_here

# Optional: Ollama model name
# Must be qwen2 or qwen2.5 — qwen:latest does NOT support tool calling.
# Recommended: qwen2.5:7b  (run: ollama pull qwen2.5:7b)
OLLAMA_MODEL=qwen2.5:7b

# Optional: Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: SQLite database file path (default: research_history.db)
DB_PATH=research_history.db

# Optional: Agent temperature 0.0-1.0 (default: 0.3)
AGENT_TEMPERATURE=0.3
